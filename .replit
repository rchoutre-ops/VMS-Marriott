run = "python app.py"
modules = ["python-3.11"]

[deployment]
run = ["sh", "-c", "python app.py"]
deploymentTarget = "cloudrun"

# Cron: run the full daily workflow at 08:30 IST (03:00 UTC) every day.
[[crons]]
name = "Daily Marriott Run"
schedule = "0 3 * * *"
command = "python run_daily.py"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
